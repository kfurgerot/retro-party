# Production environment variables example
# Do NOT commit your real .env.prod file.

PORT=3001
ORIGIN=https://retro-party.example.com

POSTGRES_DB=retro_party
POSTGRES_USER=retro
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://retro:change_me_strong_password@postgres:5432/retro_party

SESSION_COOKIE_NAME=rp_session
SESSION_TTL_DAYS=7
BCRYPT_ROUNDS=12
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

GMAIL_USER=your.address@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
MAIL_FROM=Retro Party <your.address@gmail.com>

RESET_PASSWORD_URL_BASE=https://retro-party.example.com/reset-password
RESET_TOKEN_TTL_MINUTES=60
