# Production environment variables example
# Do NOT commit your real .env.prod file.
VITE_ENABLE_BOARD_PIXI=1

PORT=3001
ORIGIN=https://retro.karl-furgerot.fr
# Optionnel: plusieurs origines autorisees separees par des virgules
# ORIGIN=https://retro-party.example.com,https://admin.retro-party.example.com
# Autoriser aussi les IP privees LAN (mobile/tablette sur le meme reseau local)
ALLOW_PRIVATE_LAN_ORIGINS=1

POSTGRES_DB=retro_party
POSTGRES_USER=retro
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://retro:change_me_strong_password@postgres:5432/retro_party

SESSION_COOKIE_NAME=rp_session
SESSION_TTL_DAYS=7
BCRYPT_ROUNDS=12
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30
MAIL_TEST_RATE_LIMIT_WINDOW_MS=600000
MAIL_TEST_RATE_LIMIT_MAX=5

GMAIL_USER=your.address@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
MAIL_FROM=Retro Party <your.address@gmail.com>

RESET_PASSWORD_URL_BASE=https://retro.karl-furgerot.fr/reset-password
RESET_TOKEN_TTL_MINUTES=60
ENABLE_WHO_SAID_IT_MINIGAME=0

# OAuth providers (optional but recommended)
OAUTH_STATE_SECRET=change_me_to_a_long_random_secret
OAUTH_CALLBACK_BASE_URL=https://retro.karl-furgerot.fr
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_TENANT_ID=common
