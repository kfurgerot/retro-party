# If you serve frontend + backend under same domain via reverse proxy, you can omit this.
# VITE_BACKEND_URL=https://retro-party.example.com
VITE_BACKEND_URL=http://localhost:3001

# Backend Gmail SMTP variables (set these where backend runs, not in frontend builds)
# GMAIL_USER=your-address@gmail.com
# GMAIL_APP_PASSWORD=your-gmail-app-password
# MAIL_FROM=Retro Party <your-address@gmail.com>
