# Local Docker Compose variables (copy to .env.local and adjust values)

PORT=3001
ORIGIN=http://localhost:8088
# Optionnel: plusieurs origines autorisees separees par des virgules
# ORIGIN=http://localhost:8088,http://127.0.0.1:8088

POSTGRES_DB=retro_party
POSTGRES_USER=retro
POSTGRES_PASSWORD=change_me_local
DATABASE_URL=postgresql://retro:change_me_local@postgres:5432/retro_party

SESSION_COOKIE_NAME=rp_session
SESSION_TTL_DAYS=7
BCRYPT_ROUNDS=12
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30
MAIL_TEST_RATE_LIMIT_WINDOW_MS=600000
MAIL_TEST_RATE_LIMIT_MAX=5

GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_FROM=
RESET_PASSWORD_URL_BASE=http://localhost:8088/reset-password
RESET_TOKEN_TTL_MINUTES=60
